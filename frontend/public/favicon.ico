    <style>
    /* When body has this attribute, hide the Google Places dropdown globally.
       We set it only while a blocked field is focused so real address fields are not affected. */
    body[data-disable-pac="1"] .pac-container {
        display: none !important;
        pointer-events: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
    }
    </style>

    <script>
    (function () {
        "use strict";

        // selectors for the fields we want to block (add more selectors as needed)
        var blockedSelectors = [
            'input[name="username"]',
            'input[name="email"]',
            '#username',
            '#user_login',
            'input[type="email"].login-email' // example extra
        ];

        // Helper: act on a field element
        function sanitizeField(field) {
            if (!field || field._nl_sanitized) return;
            try {
                field.setAttribute('autocomplete', 'off'); // native browser
                field.removeAttribute('aria-haspopup'); // sometimes google sets this
                field.classList.remove('pac-target-input'); // remove google class if present
                field.classList.add('nl-no-pac'); // marker we added
                // focus/blur handlers: while focused, hide pac-container globally
                field.addEventListener('focus', function () {
                    document.body.setAttribute('data-disable-pac', '1');
                    // small timeout to also remove pac-target-input if google re-adds it
                    setTimeout(function () {
                        field.classList.remove('pac-target-input');
                    }, 50);
                }, {passive:true});
                field.addEventListener('blur', function () {
                    // restore
                    document.body.removeAttribute('data-disable-pac');
                    // ensure class removed
                    setTimeout(function () {
                        field.classList.remove('pac-target-input');
                    }, 50);
                }, {passive:true});

                // defensive interval to remove pac classes if some other script keeps re-adding them
                var tries = 0;
                var iv = setInterval(function () {
                    tries++;
                    field.setAttribute('autocomplete', 'off');
                    field.classList.remove('pac-target-input');
                    if (tries > 10) clearInterval(iv);
                }, 150);

                field._nl_sanitized = true;
            } catch (e) {
                // ignore
                console && console.warn && console.warn('nl sanitizeField error', e);
            }
        }

        // Scan existing matches
        function scanAndSanitize() {
            blockedSelectors.forEach(function (sel) {
                var nodes = document.querySelectorAll(sel);
                if (!nodes) return;
                nodes.forEach(function (n) {
                    sanitizeField(n);
                });
            });
        }

        // Run immediately once DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', scanAndSanitize);
        } else {
            scanAndSanitize();
        }

        // MutationObserver to catch fields added later (AJAX or dynamically by plugin)
        var observer = new MutationObserver(function (mutations) {
            mutations.forEach(function (m) {
                // check added nodes quickly
                if (m.addedNodes && m.addedNodes.length) {
                    scanAndSanitize();
                }
                // attributes changes (some libs add pac-target-input later)
                if (m.type === 'attributes' && m.target) {
                    var t = m.target;
                    if (t.matches && blockedSelectors.some(function (s) { return t.matches(s); })) {
                        sanitizeField(t);
                    }
                }
            });
        });

        observer.observe(document.documentElement || document.body, {
            childList: true,
            subtree: true,
            attributes: true,
            attributeFilter: ['class', 'autocomplete', 'aria-haspopup', 'id', 'name']
        });

        // As a last resort also listen for focusin so if something slips through we hide dropdown while focused
        document.addEventListener('focusin', function (e) {
            var el = e.target;
            if (!el) return;
            try {
                // if the focused element matches our blocked list, hide pac globally
                var matches = blockedSelectors.some(function (sel) {
                    try { return el.matches(sel); } catch (err) { return false; }
                });
                if (matches) {
                    document.body.setAttribute('data-disable-pac', '1');
                    // remove class immediate
                    el.classList.remove('pac-target-input');
                    el.setAttribute('autocomplete', 'off');
                } else {
                    document.body.removeAttribute('data-disable-pac');
                }
            } catch (err) {}
        }, true);

        // Extra defensive: periodically remove pac-target-input on matching fields for a short while after load
        var cleanupTries = 0;
        var cleanupTimer = setInterval(function () {
            cleanupTries++;
            scanAndSanitize();
            if (cleanupTries > 20) clearInterval(cleanupTimer);
        }, 300);

    })();
    </script>
    <script>
document.addEventListener("DOMContentLoaded", function () {

    // Observe the entire body for new infowindows
    const observer = new MutationObserver((mutationsList) => {
        mutationsList.forEach(mutation => {
            mutation.addedNodes.forEach(node => {
                if (!node.querySelector) return;

                const wrapper = node.querySelector('.fc-infobox-content-wrapper');
                if (!wrapper) return;

                const btn = wrapper.querySelector('.message-now-btn[data-user-role="basic_free_plan"]');
                if (!btn) return;

                // Prevent duplicate replacements
                if (wrapper.classList.contains('basic-plan-replaced')) return;
                wrapper.classList.add('basic-plan-replaced');

                // Hide wrapper to prevent flash
                wrapper.style.visibility = 'hidden';

                // Replace content
                wrapper.innerHTML = `
                    <div class="basic-plan-note" style="
                        padding: 12px;
                        font-size: 14px;
                        line-height: 1.5;
                        color: #333;
                        text-align: center;
                    ">
                        <h3>Out of network pilot</h3>
                        Good news! We have a pilot we've worked with before in your area.
                        Even though this isn't one of our in-network partner pilots, just reach out to
                        <a href="mailto:support@lostpetdronerecovery.com">
                            support@lostpetdronerecovery.com
                        </a>
                        and we can get you connected!
                    </div>
                `;

                wrapper.style.visibility = 'visible';
            });
        });
    });

    observer.observe(document.body, { childList: true, subtree: true });
});
</script>

