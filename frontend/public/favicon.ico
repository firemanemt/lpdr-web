<script id="ur-location-sync-single-js-js-after">
(function($){
  'use strict';

  var STREET_SELECTORS = urLocationSync.street_selectors;
  var HIDDEN_NAMES = urLocationSync.lat_lng_field_names;
  var DEBUG = urLocationSync.debug;

  function log(){ if(DEBUG) console.log.apply(console, arguments); }

  function ensureHiddenFields($context) {
    var $h = {};
    HIDDEN_NAMES.forEach(function(name){
      var $e = $context.find('input[name="'+name+'"]');
      if(!$e.length){
        var $form = $context.closest('form');
        var $hidden = $('<input/>',{type:'hidden',name:name});
        if($form.length) $form.append($hidden); else $('body').append($hidden);
        $h[name] = $hidden;
      } else $h[name] = $e.first();
    });
    return $h;
  }

  function buildPayloadFromPlace(place, val){
    var c={};
    (place.address_components||[]).forEach(function(x){
      if(x.types.indexOf('street_number') !== -1) c.num=x.long_name;
      if(x.types.indexOf('route') !== -1) c.route=x.long_name;
      if(x.types.indexOf('locality') !== -1) c.city=x.long_name;
      if(x.types.indexOf('administrative_area_level_1') !== -1) c.state=x.short_name||x.long_name;
      if(x.types.indexOf('postal_code') !== -1) c.postal=x.long_name;
      if(x.types.indexOf('country') !== -1) c.country=x.long_name;
    });
    var street=(c.num?c.num+' ':'')+(c.route||'');
    var lat=null,lng=null;
    if(place && place.geometry && place.geometry.location){
      if(typeof place.geometry.location.lat === 'function'){
        lat=place.geometry.location.lat();
        lng=place.geometry.location.lng();
      } else {
        lat = place.geometry.location.lat || null;
        lng = place.geometry.location.lng || null;
      }
    }
    return {
      address: street||val||'',
      city:c.city||'',state:c.state||'',postal:c.postal||'',country:c.country||'',
      lat:lat,lng:lng
    };
  }

  function initAutocompleteOnce($i){
    if($i.data('ur-auto')) return;
    $i.data('ur-auto',true);

    function tryInit(){
      if(!window.google||!google.maps||!google.maps.places){ setTimeout(tryInit,200); return; }
      try {
        var ac=new google.maps.places.Autocomplete($i.get(0),{types:['address']});
        $i.data('ur-ac', ac);
        ac.addListener('place_changed',function(){
          var p=ac.getPlace();
          var payload=buildPayloadFromPlace(p,$i.val());
          var json=JSON.stringify(payload);
          var $form=$i.closest('form');
          var h=ensureHiddenFields($form.length?$form:$('body'));
          HIDDEN_NAMES.forEach(function(n){ h[n].val(json).trigger('change'); });
          log("Payload (place_changed):",payload);
        });
      } catch(e){
        log("Autocomplete init error", e);
      }
    }
    tryInit();
  }

  // ensure hidden fields have at least the address before submit
  // returns a Promise that resolves once hidden fields are filled
  function ensureBeforeSubmit($context){
    return new Promise(function(resolve){
      var h = ensureHiddenFields($context);
      // if already filled, do nothing
      var $h = h[HIDDEN_NAMES[0]];
      if($h.length && $h.val()){
        resolve();
        return;
      }

      // find street input in context or globally
      var $street = null;
      for(var i=0;i<STREET_SELECTORS.length;i++){
        var $c = $context.find(STREET_SELECTORS[i]);
        if($c.length){ $street = $c.first(); break; }
      }
      if(!$street || !$street.length){
        // fallback: global
        for(var i=0;i<STREET_SELECTORS.length;i++){
          var $c = $(STREET_SELECTORS[i]);
          if($c.length){ $street = $c.first(); break; }
        }
      }

      var val = $street && $street.length ? $street.val() : '';

      // If this field has an Autocomplete instance attached, prefer the structured place
      var ac = null;
      try {
        if ($street && $street.length) {
          ac = $street.data('ur-ac') || null;
        }
      } catch (e) {
        ac = null;
      }

      // Helper to set and resolve
      function setAndResolve(payload){
        var json = JSON.stringify(payload);
        HIDDEN_NAMES.forEach(function(n){ h[n].val(json).trigger('change'); });
        resolve();
      }

      if (ac && typeof ac.getPlace === 'function') {
        var p = null;
        try { p = ac.getPlace(); } catch(e){ p = null; }
        if (p && p.address_components && p.geometry && p.geometry.location) {
          var payload = buildPayloadFromPlace(p, $street.val());
          setAndResolve(payload);
          log("Payload (ensureBeforeSubmit from place):", payload);
          return;
        }
      }

      // If Google maps is available, try geocoding the typed address to obtain structured components
      if (window.google && google.maps && val && val.trim()) {
        var handled = false;

        // 1) Geocoder attempt
        try {
          if (google.maps.Geocoder) {
            var geocoder = new google.maps.Geocoder();
            geocoder.geocode({ address: val }, function(results, status){
              if (status === google.maps.GeocoderStatus.OK && results && results[0]) {
                var payload = buildPayloadFromPlace(results[0], val);
                setAndResolve(payload);
                log("Payload (geocoder result):", payload);
                handled = true;
                return;
              }
              // if geocoder didn't find, try Places findPlaceFromQuery
              tryPlacesFallback();
            });
            return; // wait for async geocoder callback
          } else {
            tryPlacesFallback();
          }
        } catch(e){
          log("Geocoder error", e);
          tryPlacesFallback();
        }

        // 2) PlacesService fallback (better for partial/ambiguous typed addresses)
        function tryPlacesFallback(){
          try {
            if (google.maps.places && google.maps.places.PlacesService) {
              var ps = new google.maps.places.PlacesService(document.createElement('div'));
              var fields = ['address_components','geometry','formatted_address'];
              ps.findPlaceFromQuery({ query: val, fields: fields, locationBias: 'IP' }, function(results, status){
                if (status === google.maps.places.PlacesServiceStatus.OK && results && results[0]) {
                  var payload = buildPayloadFromPlace(results[0], val);
                  setAndResolve(payload);
                  log("Payload (places findPlaceFromQuery result):", payload);
                  handled = true;
                  return;
                }
                // final fallback
                var fallback = {address:val,city:'',state:'',postal:'',country:'',lat:null,lng:null};
                setAndResolve(fallback);
                log("Payload (ensureBeforeSubmit final fallback):", fallback);
              });
              return;
            }
          } catch(e){
            log("PlacesService error", e);
          }
          // if no google places available, fallback now
          var fallback2 = {address:val,city:'',state:'',postal:'',country:'',lat:null,lng:null};
          setAndResolve(fallback2);
          log("Payload (ensureBeforeSubmit fallback):", fallback2);
        }

        return;
      }

      // final fallback: simple address-only payload
      var json = {address:val,city:'',state:'',postal:'',country:'',lat:null,lng:null};
      HIDDEN_NAMES.forEach(function(n){ h[n].val(JSON.stringify(json)).trigger('change'); });
      log("Payload (ensureBeforeSubmit fallback no google):", json);
      resolve();
    });
  }

function attachSubmit(){

  // FAST SYNC PLACE FILLER
  function fastFill($form){
    try{
      var $street=null;
      for(var i=0;i<STREET_SELECTORS.length;i++){
        var $c=$form.find(STREET_SELECTORS[i]);
        if($c.length){ $street=$c.first(); break; }
      }
      if(!$street) return;

      var ac=$street.data('ur-ac');
      if(ac && ac.getPlace){
        var p=ac.getPlace();
        if(p && p.address_components){
          var payload=buildPayloadFromPlace(p,$street.val());
          var json=JSON.stringify(payload);
          var h=ensureHiddenFields($form);
          HIDDEN_NAMES.forEach(n=>h[n].val(json));
        }
      }
    }catch(e){}
  }

  // CLICK HANDLER – DOES NOT BLOCK ANYTHING
  $(document).on('click','button[type="submit"],input[type="submit"]',function(){
    var $form=$(this).closest('form');
    if(!$form.length) return;
    fastFill($form);         // try to get structured place immediately
    ensureBeforeSubmit($form); // run async geocoder/places in background
    // NO preventDefault()
  });

  // NATIVE SUBMIT – DOES NOT BLOCK
  STREET_SELECTORS.forEach(function(sel){
    $(document).on('submit','form:has('+sel+')',function(){
      var $form=$(this);
      fastFill($form);
      ensureBeforeSubmit($form);
      return true; // do NOT block
    });
  });

}


  function observer(){
    var o=new MutationObserver(function(m){
      m.forEach(function(x){
        x.addedNodes.forEach(function(n){
          if(n.nodeType!==1) return;
          STREET_SELECTORS.forEach(function(sel){
            $(n).find(sel).each(function(){initAutocompleteOnce($(this));});
            if($(n).is(sel)) initAutocompleteOnce($(n));
          });
        });
      });
    });
    o.observe(document.body,{childList:true,subtree:true});
  }

  $(function(){
    // initialize on focus (as before)
    STREET_SELECTORS.forEach(function(sel){
      $(document).on('focus', sel, function(){ initAutocompleteOnce($(this)); });
    });

    // proactive initialization: call init on any matching inputs immediately
    STREET_SELECTORS.forEach(function(sel){
      $(sel).each(function(){ initAutocompleteOnce($(this)); });
    });

    attachSubmit();
    observer();

    // ensure hidden fields exist for any selector found on the page (useful for registration)
    STREET_SELECTORS.forEach(function(sel){
      $(sel).each(function(){
        var $ctx = $(this).closest('form');
        if(!$ctx.length) $ctx = $('body');
        ensureHiddenFields($ctx);
      });
    });

// --- REPLACE the old change/blur handler with this new debounced resolver ---
(function(){
  var resolveTimers = {}; // map input DOM id -> timeout id

  function attemptResolveAddress($i){
    // returns a Promise that resolves when hidden fields are set
    return new Promise(function(resolve){
      if(!$i || !$i.length){ resolve(); return; }
      var val = $i.val() || '';
      var $ctx = $i.closest('form');
      if(!$ctx.length) $ctx = $('body');
      var h = ensureHiddenFields($ctx);

      // prefer Autocomplete place if available
      var ac = $i.data('ur-ac') || null;
      try {
        if (ac && typeof ac.getPlace === 'function') {
          var p = null;
          try { p = ac.getPlace(); } catch(e){ p = null; }
          if (p && p.address_components && p.geometry && p.geometry.location) {
            var payload = buildPayloadFromPlace(p, val);
            HIDDEN_NAMES.forEach(function(n){ h[n].val(JSON.stringify(payload)).trigger('change'); });
            log("Resolved (ac.getPlace) for", val, payload);
            resolve();
            return;
          }
        }
      } catch(e){
        log("ac.getPlace error", e);
      }

      // If Google maps available try geocode -> findPlace -> fallback
      if (window.google && google.maps && val && val.trim()) {
        // Geocoder attempt
        try {
          if (google.maps.Geocoder) {
            var geocoder = new google.maps.Geocoder();
            geocoder.geocode({ address: val }, function(results, status){
              if (status === google.maps.GeocoderStatus.OK && results && results[0]) {
                var payload = buildPayloadFromPlace(results[0], val);
                HIDDEN_NAMES.forEach(function(n){ h[n].val(JSON.stringify(payload)).trigger('change'); });
                log("Resolved (geocoder) for", val, payload);
                resolve();
                return;
              }
              // try places fallback
              tryPlacesFallback();
            });
            return; // wait for async geocoder
          } else {
            tryPlacesFallback();
          }
        } catch(e){
          log("Geocoder attempt error", e);
          tryPlacesFallback();
        }

        function tryPlacesFallback(){
          try {
            if (google.maps.places && google.maps.places.PlacesService) {
              var ps = new google.maps.places.PlacesService(document.createElement('div'));
              var fields = ['address_components','geometry','formatted_address'];
              ps.findPlaceFromQuery({ query: val, fields: fields, locationBias: 'IP' }, function(results, status){
                if (status === google.maps.places.PlacesServiceStatus.OK && results && results[0]) {
                  var payload = buildPayloadFromPlace(results[0], val);
                  HIDDEN_NAMES.forEach(function(n){ h[n].val(JSON.stringify(payload)).trigger('change'); });
                  log("Resolved (places findPlaceFromQuery) for", val, payload);
                  resolve();
                  return;
                }
                // final fallback
                var fallback = {address:val,city:'',state:'',postal:'',country:'',lat:null,lng:null};
                HIDDEN_NAMES.forEach(function(n){ h[n].val(JSON.stringify(fallback)).trigger('change'); });
                log("Resolved (fallback) for", val, fallback);
                resolve();
              });
              return;
            }
          } catch(e){
            log("PlacesService error", e);
          }
          // no Google Places -> fallback now
          var fallback2 = {address:val,city:'',state:'',postal:'',country:'',lat:null,lng:null};
          HIDDEN_NAMES.forEach(function(n){ h[n].val(JSON.stringify(fallback2)).trigger('change'); });
          log("Resolved (fallback2 no places) for", val, fallback2);
          resolve();
        }
        return;
      }

      // No google or empty -> fallback immediately
      var fb = {address:val,city:'',state:'',postal:'',country:'',lat:null,lng:null};
      HIDDEN_NAMES.forEach(function(n){ h[n].val(JSON.stringify(fb)).trigger('change'); });
      log("Resolved (no google) for", val, fb);
      resolve();
    });
  }

  // Debounced handler used on blur/change so AJAX serializations will capture structured JSON
  $(document).on('blur change', STREET_SELECTORS.join(','), function(){
    var $i = $(this);
    // clear any pending timer
    var id = $i.data('ur-resolve-id');
    if (id) { clearTimeout(id); $i.removeData('ur-resolve-id'); }
    // debounce 500ms to allow session of typing to finish
    var t = setTimeout(function(){
      attemptResolveAddress($i).catch(function(e){ log("attemptResolveAddress error", e); });
    }, 500);
    $i.data('ur-resolve-id', t);
    // also ensure we call the older quick fallback immediately so hidden exist while waiting
    var $ctx = $i.closest('form'); if(!$ctx.length) $ctx = $('body');
    var h = ensureHiddenFields($ctx);
    var val = $i.val() || '';
    var json = JSON.stringify({address:val,city:'',state:'',postal:'',country:'',lat:null,lng:null});
    HIDDEN_NAMES.forEach(function(n){ h[n].val(json).trigger('change'); });
  });
})();

  });

})(jQuery);
//# sourceURL=ur-location-sync-single-js-js-after
</script>
