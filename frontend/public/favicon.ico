.assign-swal-success-popup) .swal2-cancel, n.swal2-popup:not(.assign-swal-success-popup) .swal2-deny, n.swal2-popup:not(.assign-swal-success-popup) .swal2-close { display: inline-block !important; visibility: visible !important; width: auto !important; height: auto !important; margin: initial !important; padding: initial !important; border: initial !important; }n';
        document.head.appendChild(s2);
        // Ensure our custom cancel button is visible for assignment confirmation popups
        var s3 = document.createElement('style');
        s3.id = 'assign-swal-cancel-override';
        s3.innerHTML = '.swal2-popup.assign-swal-popup .lpdr-swal-cancel{display:inline-block!important;visibility:visible!important;}';
        document.head.appendChild(s3);
        // Additional mobile-specific tweak for the success popup only
        var s4 = document.createElement('style');
        s4.id = 'assign-swal-success-style';
        s4.innerHTML = 'n/* Scoped: make success popup fit nicely on small screens only */n.swal2-popup.assign-swal-success-popup{max-width:92vw!important;width:auto!important;padding:14px!important;box-sizing:border-box!important;margin:0 auto!important;font-size:15px!important;border-radius:8px!important;overflow:hidden!important;}n.swal2-popup.assign-swal-success-popup .swal2-title{font-size:16px!important;margin-top:4px!important;text-align:center!important;}n.swal2-popup.assign-swal-success-popup .swal2-icon{width:72px!important;height:72px!important;margin:6px auto!important;display:block!important;}n.swal2-popup.assign-swal-success-popup .swal2-html-container{font-size:14px!important;line-height:1.35!important;padding:8px 6px!important;text-align:center!important;margin:0!important;}n.swal2-popup.assign-swal-success-popup .assign-swal-success-message{text-align:center!important;margin:0;}n.swal2-popup.assign-swal-success-popup .assign-swal-success-cta-wrap{text-align:center!important;padding-top:14px!important;}n.swal2-popup.assign-swal-success-popup .assign-swal-success-cta{display:inline-flex!important;justify-content:center!important;align-items:center!important;width:140px!important;max-width:140px!important;padding:10px 18px!important;margin:0 auto!important;border:0!important;border-radius:4px!important;background:#4c5fb8!important;color:#fff!important;font-size:16px!important;line-height:1!important;cursor:pointer!important;box-shadow:none!important;}n.swal2-popup.assign-swal-success-popup .swal2-actions{display:none!important;}n@media (min-width:481px){.swal2-popup.assign-swal-success-popup{max-width:560px!important;padding:20px!important;}}n';
