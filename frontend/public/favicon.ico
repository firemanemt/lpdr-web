<style id='lpdr-case-counter-inline-style-inline-css'>

        .lpdr-case-counter {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 1.25rem 1.5rem;
            border-radius: 18px;
            background: transparent;
            border: none;
            box-shadow: none;
            max-width: 450px;
            margin: 0 auto;
            text-align: center;
            font-family: 'Black Ops One', cursive;
        }
        .lpdr-case-counter .counter-number {
            font-size: 3.75rem;
            font-weight: 400;
            color: #ffffff;
            line-height: 1;
        }
        .lpdr-case-counter .counter-label {
            margin-top: 0.35rem;
            font-size: 0.95rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #ffffff;
            font-weight: 400;
            white-space: nowrap;
        }
        @media (max-width: 768px) {
            .lpdr-case-counter {
                padding: 1rem 1rem;
                max-width: 100%;
            }
            .lpdr-case-counter .counter-number {
                font-size: 2.75rem;
            }
        }
    
/*# sourceURL=lpdr-case-counter-inline-style-inline-css */
