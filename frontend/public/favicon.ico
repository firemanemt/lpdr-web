<!-- start Simple Custom CSS and JS -->
<script>
 

// Initialize Google Autocomplete and validate on form submit
(function() {
    // Wait for the DOM element and Google Maps API to be ready
    function waitForAutocompleteElements(maxAttempts = 20, interval = 300) {
        let attempts = 0;
        const timer = setInterval(() => {
            const input = document.getElementById('street_address');
            const hiddenField = document.getElementById('user_location_source');
            
            if (typeof google !== 'undefined' && google.maps && input && hiddenField) {
                clearInterval(timer);
                attachAutocomplete(input, hiddenField);
            } else {
                attempts++;
                if (attempts >= maxAttempts) {
                    clearInterval(timer);
                    console.warn('Autocomplete initialization failed: elements not found or Google Maps not loaded.');
                }
            }
        }, interval);
    }

    // Attach the Google Autocomplete listener
    function attachAutocomplete(input, hiddenField) {
        const autocomplete = new google.maps.places.Autocomplete(input);
        autocomplete.addListener('place_changed', function () {
            const place = autocomplete.getPlace();
            if (!place.geometry) return;

            const components = {
                address: place.formatted_address,
                lat: place.geometry.location.lat(),
                lng: place.geometry.location.lng(),
                city: '',
                state: '',
                country: '',
                postal: ''
            };

            place.address_components.forEach(function(comp) {
                if (comp.types.includes('locality')) components.city = comp.long_name;
                if (comp.types.includes('administrative_area_level_1')) components.state = comp.long_name;
                if (comp.types.includes('country')) components.country = comp.long_name;
                if (comp.types.includes('postal_code')) components.postal = comp.long_name;
            });

            hiddenField.value = JSON.stringify(components); // Save JSON in hidden field
            console.log('user_location_source updated:', hiddenField.value);

            // Optional: enforce full address
            if (!components.city || !components.state || !components.country || !components.postal) {
                alert('Please enter a more specific address including city, state, country, and postal code.');
            }
        });
    }

    // Start polling on window load
    window.addEventListener('load', () => {
        waitForAutocompleteElements();
    });
})();
</script>
<!-- end Simple Custom CSS and JS -->
<!-- start Simple Custom CSS and JS -->
<script>
jQuery(document).ready(function ($) {

// Run after page load

    $(".assign-now-btn").on("click", function (e) {
        e.preventDefault();		
		  var postId = $(this).closest('div[post-id]').attr('post-id');
		
	     if (!postId) {
            alert("Missing post ID.");
            return;
        }

        // Send AJAX request
        $.ajax({
            url: ajaxurl, // WordPress automatically exposes ajaxurl in frontend
            type: "POST",
            data: {
                action: "update_assigned_user",
                nonce: assignUser.nonce, // localized in PHP
                post_id: postId,
            },
            success: function (response) {
                if (response.success) {
                    Swal.fire({
                        icon: "success",
                        title: "Assigned!",
                        text: response.data,
                        timer: 2000,
                        showConfirmButton: false
                    });

                    // Optionally disable button or change text
                    $(`[data-post-id='${postId}']`).text("Assigned").prop("disabled", true);
                } else {
                    Swal.fire({
                        icon: "error",
                        title: "Error",
                        text: response.data || "Something went wrong.",
                    });
                }
            },
            error: function () {
                Swal.fire({
                    icon: "error",
                    title: "Request Failed",
                    text: "Could not connect to the server.",
                });
            }
        });

    });
});

</script>
<!-- end Simple Custom CSS and JS -->
