            } else {
                if (confirm(message)) doSubmit(); else try{ btn.blur(); }catch(e){}
            }
        } catch(e){}
    }, true);

    // Show a success popup when redirected with ?assigned=success
    try {
        var params = new URLSearchParams(window.location.search || '');
        if (params.get('assigned') === 'success') {
            if (window.Swal && typeof Swal.fire === 'function') {
                Swal.fire({
                    icon: 'success',
                    title: 'Assigned',
                    html: '<div class="assign-swal-success-message">Case successfully assigned to you. You can view it in your profile under "My Active Cases".</div><div class="assign-swal-success-cta-wrap"><button type="button" class="assign-swal-success-cta">OK</button></div>',
                    showConfirmButton: false,
                    showCancelButton: false,
                    showCloseButton: false,
                    allowOutsideClick: false,
                    heightAuto: false,
                    target: document.body,
                    customClass: { popup: 'assign-swal-success-popup' },
                    didOpen: function() {
                        try {
                            var popup = Swal.getPopup ? Swal.getPopup() : null;
                            var container = Swal.getContainer ? Swal.getContainer() : null;
                            var customButton = popup ? popup.querySelector('.assign-swal-success-cta') : null;

                            // Detect any transformed ancestor which can change how fixed positioning behaves
                            function findTransformedAncestor(node) {
                                var el = node.parentElement;
                                while (el && el !== document.documentElement) {
                                    try {
                                        var cs = window.getComputedStyle(el);
                                        if (cs && cs.transform && cs.transform !== 'none') return el;
                                    } catch (err) {}
                                    el = el.parentElement;
                                }
                                return null;
                            }

                            var transformed = findTransformedAncestor(document.body);

                            // If a transformed ancestor exists, move the Swal container to the documentElement
                            if (transformed && container && container.parentElement !== document.documentElement) {
                                try {
                                    document.documentElement.appendChild(container);
                                } catch (e) {}
                            }

                            // Force container full-screen + centered overlay so popup is never clipped
                            if (container) {
                                container.style.position = 'fixed';
                                container.style.left = '0';
                                container.style.top = '0';
                                container.style.right = '0';
                                container.style.bottom = '0';
                                container.style.width = '100%';
                                container.style.height = '100%';
                                container.style.display = 'flex';
                                container.style.alignItems = 'center';
                                container.style.justifyContent = 'center';
                                container.style.zIndex = '2147483647';
                            }

                            if (popup) {
                                popup.style.position = 'relative';
                                popup.style.left = 'auto';
                                popup.style.top = 'auto';
                                popup.style.transform = 'none';
                                popup.style.margin = '0 auto';
                                popup.style.maxHeight = '90vh';
                                popup.style.zIndex = '2147483648';
                            }

                            if (customButton) {
                                customButton.addEventListener('click', function() {
                                    try { Swal.close(); } catch (e) {}
                                });
                            }

                            // Ensure modal is centered and not clipped by transformed ancestors
                            ensureSwalCentered(popup, container);
                        } catch (e) {}
                    }
                });
            } else {
                // fallback
                try { alert('Case successfully assigned to you.'); } catch(e){}
            }

            // remove the query param so reloading doesn't show the popup again
            try {
                params.delete('assigned');
                var newSearch = params.toString();
                var newUrl = window.location.pathname + (newSearch ? '?' + newSearch : '') + window.location.hash;
                history.replaceState(null, '', newUrl);
            } catch (e) {}
        }
    } catch (e) {}

})();
//# sourceURL=swal2-js-after
</script>
