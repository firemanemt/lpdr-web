                                    var denyGlobal = popup ? popup.querySelectorAll('.swal2-deny') : [];
                                    denyGlobal.forEach && denyGlobal.forEach(function(n){ try{ n.remove(); }catch(e){} });
                                    var cancel = actions.querySelector('.lpdr-swal-cancel');
                                    if (cancel) { cancel.style.display = 'inline-block'; cancel.style.visibility = 'visible'; }
                                }
                                ensureSwalCentered(popup, container);
                            } catch(e){}
                        }
                    }).then(function(result){ if (result && result.isConfirmed) doSubmit(); else try{ btn.blur(); }catch(e){}; __lpdr_assign_swal_open = false; }).catch(function(err){
                        __lpdr_assign_swal_open = false;
                        console.error('Swal.fire promise rejected (click handler)', err);
                        if (confirm(message)) doSubmit(); else try{ btn.blur(); }catch(e){}
                    });
                } catch (swalErr) {
                    __lpdr_assign_swal_open = false;
                    console.error('Swal.fire failed in click handler, falling back to confirm()', swalErr);
                    if (confirm(message)) doSubmit(); else try{ btn.blur(); }catch(e){}
