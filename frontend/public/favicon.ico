    // Helper to ensure SweetAlert modals are centered and not clipped by transformed ancestors
    function ensureSwalCentered(popup, container) {
        try {
            if (!container && window.Swal && typeof Swal.getContainer === 'function') {
                container = Swal.getContainer();
            }
            if (!popup && window.Swal && typeof Swal.getPopup === 'function') {
                popup = Swal.getPopup();
            }
            if (!container) return;

            // Force the Swal container to top-level body so parent wrappers cannot constrain/offset it.
            if (container.parentElement !== document.body) {
                try { document.body.appendChild(container); } catch (e) {}
            }

            // Lock the overlay to the visible viewport.
            container.style.setProperty('position', 'fixed', 'important');
            container.style.setProperty('left', '0', 'important');
            container.style.setProperty('top', '0', 'important');
            container.style.setProperty('right', '0', 'important');
            container.style.setProperty('bottom', '0', 'important');
            container.style.setProperty('width', '100vw', 'important');
            container.style.setProperty('height', '100vh', 'important');
            container.style.setProperty('display', 'flex', 'important');
            container.style.setProperty('align-items', 'center', 'important');
            container.style.setProperty('justify-content', 'center', 'important');
            container.style.setProperty('padding', '16px', 'important');
            container.style.setProperty('box-sizing', 'border-box', 'important');
            container.style.setProperty('z-index', '2147483647', 'important');

            if (popup) {
                // Center against the current visible viewport, not the page origin.
                var vv = window.visualViewport;
                var left = vv ? (vv.offsetLeft + (vv.width / 2)) : (window.innerWidth / 2);
                var top = vv ? (vv.offsetTop + (vv.height / 2)) : (window.innerHeight / 2);

                popup.style.setProperty('position', 'fixed', 'important');
                popup.style.setProperty('left', left + 'px', 'important');
                popup.style.setProperty('top', top + 'px', 'important');
                popup.style.setProperty('transform', 'translate(-50%, -50%)', 'important');
                popup.style.setProperty('margin', '0', 'important');
                popup.style.setProperty('max-height', '90vh', 'important');
                popup.style.setProperty('max-width', '92vw', 'important');
                popup.style.setProperty('z-index', '2147483648', 'important');
            }
        } catch (e) {}
    }

    // Track the last actionable button clicked/touched so we can handle form submits on mobile
    var __lpdr_last_action_button = null;

    function trackActionEvent(evt) {
        try {
            var t = evt.target;
            var b = (t && typeof t.closest === 'function') ? t.closest('button') : null;
            if (b && b.classList) {
                if (b.classList.contains('assign-btn') || b.classList.contains('complete-btn') || b.classList.contains('unassign-btn')) {
                    __lpdr_last_action_button = b;
                    // clear after a short time
                    setTimeout(function(){ __lpdr_last_action_button = null; }, 2500);
                }
            }
        } catch(e){}
    }

    ['pointerdown','touchstart','click'].forEach(function(ev){ document.addEventListener(ev, trackActionEvent, true); });

    // Intercept form submissions (capture phase) to show confirmation on mobile/browser submits
    document.addEventListener('submit', function(e){
        try {
            var form = e.target;
            var submitter = e.submitter || __lpdr_last_action_button;
            if (!submitter || !submitter.classList) return;

            var action = null;
            if (submitter.classList.contains('assign-btn')) action = 'assign';
            else if (submitter.classList.contains('complete-btn')) action = 'complete';
            else if (submitter.classList.contains('unassign-btn')) action = 'unassign';
            if (!action) return;

            // prevent immediate submit until user confirms
            e.preventDefault();

            var title = '';
            var message = '';
            var confirmText = 'Yes';

            if (action === 'assign') {
                title = 'Assign case';
                message = 'Are you sure you want to assign this case to yourself?';
                confirmText = 'Yes, assign';
            } else if (action === 'complete') {
                title = 'Mark Complete';
                message = 'Mark this case as Complete? This action cannot be undone.';
                confirmText = 'Yes, complete';
            } else if (action === 'unassign') {
                title = 'Unassign case';
                message = 'Are you sure you want to unassign this case?';
                confirmText = 'Yes, unassign';
            }

            function doSubmit() {
                // remove listeners to avoid loops, then submit
                try { form.removeEventListener('submit', arguments.callee, true); } catch(e){}
                try { form.submit(); } catch(e){ /* fallback */ }
            }

            // Prefer SweetAlert when available (use on all viewports). Fall back to native confirm if Swal isn't present or fails.
            if (window.Swal && typeof Swal.fire === 'function') {
                try {
                    Swal.fire({
                        title: title,
                        text: message,
                        icon: 'question',
                        heightAuto: false,
                        // append to body to keep SweetAlert stable (we move the container if needed)
                        target: document.body,
                        showDenyButton: false,
                        showCancelButton: true,
                        confirmButtonText: confirmText,
                        cancelButtonText: 'Cancel',
                        reverseButtons: true,
                        width: 'auto',
                        customClass: { popup: 'assign-swal-popup', cancelButton: 'lpdr-swal-cancel' },
                        didOpen: function() {
                            try {
                                var popup = Swal.getPopup ? Swal.getPopup() : null;
                                var container = Swal.getContainer ? Swal.getContainer() : null;
                                var actions = Swal.getActions ? Swal.getActions() : (popup ? popup.querySelector('.swal2-actions') : null);
                                if (actions) {
                                    // remove any deny button nodes that may be injected by other scripts
                                    var denies = actions.querySelectorAll('.swal2-deny');
                                    denies.forEach(function(n){ try{ n.remove(); }catch(e){} });
                                    var denyGlobal = popup ? popup.querySelectorAll('.swal2-deny') : [];
                                    denyGlobal.forEach && denyGlobal.forEach(function(n){ try{ n.remove(); }catch(e){} });
                                    var cancel = actions.querySelector('.lpdr-swal-cancel');
                                    if (cancel) { cancel.style.display = 'inline-block'; cancel.style.visibility = 'visible'; }
                                }
                                ensureSwalCentered(popup, container);
                                if (window.visualViewport && !window.__lpdrSwalRecenterBound) {
                                    window.__lpdrSwalRecenterBound = true;
                                    window.visualViewport.addEventListener('resize', function(){
                                        try { ensureSwalCentered(Swal.getPopup ? Swal.getPopup() : null, Swal.getContainer ? Swal.getContainer() : null); } catch(e) {}
                                    }, { passive: true });
                                    window.visualViewport.addEventListener('scroll', function(){
                                        try { ensureSwalCentered(Swal.getPopup ? Swal.getPopup() : null, Swal.getContainer ? Swal.getContainer() : null); } catch(e) {}
                                    }, { passive: true });
                                }
                            } catch(e){}
                        }
                    }).then(function(result){
                        if (result && result.isConfirmed) doSubmit();
                        else try { submitter.blur(); } catch(e){}
                    }).catch(function(err){
                        console.error('Swal.fire promise rejected (submit handler)', err);
                        if (confirm(message)) doSubmit();
                        else try { submitter.blur(); } catch(e){}
                    });
                } catch (swalErr) {
                    console.error('Swal.fire failed, falling back to confirm()', swalErr);
                    if (confirm(message)) doSubmit();
                    else try { submitter.blur(); } catch(e){}
                }
            } else {
                if (confirm(message)) doSubmit();
                else try { submitter.blur(); } catch(e){}
            }

        } catch(err){}
    }, true);

    // Also intercept clicks/taps on actionable buttons in the capture phase (helps on some mobile browsers)
    document.addEventListener('click', function(ev){
        try {
            // Submit handler above is authoritative; this legacy click interceptor caused conflicts.
            return;
            var t = ev.target;
            var btn = (t && typeof t.closest === 'function') ? t.closest('button') : null;
            if (!btn) btn = t;
            if (!btn || !btn.classList) return;

            if (!(btn.classList.contains('assign-btn') || btn.classList.contains('complete-btn') || btn.classList.contains('unassign-btn'))) return;

            // Prevent native action and show confirmation
            ev.preventDefault();
            ev.stopPropagation();

            var action = btn.classList.contains('assign-btn') ? 'assign' : (btn.classList.contains('complete-btn') ? 'complete' : 'unassign');
            var title = '', message = '', confirmText = 'Yes';
            if (action === 'assign') { title='Assign case'; message='Are you sure you want to assign this case to yourself?'; confirmText='Yes, assign'; }
            else if (action === 'complete') { title='Mark Complete'; message='Mark this case as Complete? This action cannot be undone.'; confirmText='Yes, complete'; }
            else { title='Unassign case'; message='Are you sure you want to unassign this case?'; confirmText='Yes, unassign'; }

            var form = btn.closest('form');
            function doSubmit(){ try { form.submit(); } catch(e){} }

            // Always prefer SweetAlert when available; fall back to native confirm on error.
            if (window.Swal && typeof Swal.fire === 'function') {
                if (__lpdr_assign_swal_open) return;
                __lpdr_assign_swal_open = true;
                try {
                    Swal.fire({
                        title: title,
                        text: message,
                        icon: 'question',
                        heightAuto: false,
                        target: document.body,
                        showDenyButton: false,
                        showCancelButton: true,
                        confirmButtonText: confirmText,
                        cancelButtonText: 'Cancel',
                        reverseButtons: true,
                        width: 'auto',
                        customClass: { popup: 'assign-swal-popup', cancelButton: 'lpdr-swal-cancel' },
                        didOpen: function() {
                            try {
                                var popup = Swal.getPopup ? Swal.getPopup() : null;
